{
  "name": "amelias-app",
  "version": "1.0.0",
  "description": "",
  "main": "main.js",
  "scripts": {
    "rebuild:node": "npm rebuild better-sqlite3",
    "rebuild:electron": "electron-rebuild -f -w better-sqlite3",
    "postinstall": "npm run rebuild:electron",
    "dev": "npm run rebuild:node && nodemon src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "electron:start": "npm run rebuild:electron && npm run build && electron .",
    "electron:pack": "npm run rebuild:electron && npm run build && electron-builder --win"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "knex": "^3.1.0",
    "morgan": "^1.10.1",
    "winston": "^3.19.0"
  },
  "build": {
    "appId": "com.amelias.app",
    "productName": "Amelias App",
    "win": {
      "icon": "assets/icon.ico"
    },
    "files": [
      "dist/**/*",
      "main.js",
      "node_modules/**/*",
      "package.json",
      "assets/**/*",
      {
        "from": "../frontend/dist",
        "to": "frontend"
      },
      {
        "from": "../db",
        "to": "db"
      }
    ],
    "directories": {
      "output": "release"
    }
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/morgan": "^1.9.10",
    "@types/node": "^25.5.0",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "nodemon": "^3.1.14",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
